<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Expiration_Date__c</fullName>
    <description>Warranty expiration date, automatically calculated as the Start Date plus the Warranty Term in months.</description>
    <externalId>false</externalId>
    <formula>ADDMONTHS(Start_Date__c, Warranty_Term_Months__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Expiration Date</label>
    <required>false</required>
    <type>Date</type>
</CustomField>
