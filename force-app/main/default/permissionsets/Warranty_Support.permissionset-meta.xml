<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Warranty Support</label>
    <description>Grants Support agents Read, Create, and Edit access to Warranty records and their fields.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Warranty__c</object>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Warranty__c.Product__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Warranty__c.Start_Date__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Warranty__c.Warranty_Term_Months__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Warranty__c.Status__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Warranty__c.Expiration_Date__c</field>
        <editable>false</editable>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
